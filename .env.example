# ═══════════════════════════════════════════════════════════════════
#  Yuno AI Agent Platform — Environment Configuration
#  Copy to .env and fill in your values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | staging | production

# ── Security (ARB-001) ────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32

ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Comma-separated API keys for service accounts
API_KEYS=

ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database (ARB-002) ────────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./yuno.db

# Production (PostgreSQL) — uncomment and fill:
# DATABASE_URL=postgresql+asyncpg://yuno:PASSWORD@postgres:5432/yuno_platform
# POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis EventBus (ARB-003) ──────────────────────────────────────
# Leave empty for dev (uses in-process asyncio.Queue)
REDIS_URL=
# Production: redis://:PASSWORD@redis:6379/0
# REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379/0
# REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ── LLM ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY
DEFAULT_MODEL=gpt-4o-mini

# ── Telegram (ARB-008) ────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate limiting (ARB-005) ───────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_WORKFLOW_PER_MINUTE=10

# ── Observability (ARB-006) ───────────────────────────────────────
ENABLE_TRACING=false
# Production (Jaeger/Tempo/Honeycomb):
# ENABLE_TRACING=true
# OTLP_ENDPOINT=http://jaeger:4318/v1/traces

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
